@inherits LayoutComponentBase

<div class="min-h-screen bg-base-200 flex flex-col">
    <!-- Navbar -->
    <header class="navbar bg-primary text-primary-content shadow-lg z-10">
        <div class="flex-1 px-4">
            <a href="/" class="text-xl font-bold tracking-tight">PboWasm POC</a>
        </div>
        <div class="flex-none gap-2">
            <select class="select select-ghost select-sm text-primary-content focus:text-base-content" @onchange="ChangeTheme">
                <option value="light">Light</option>
                <option value="dark">Dark</option>
                <option value="cupcake">Cupcake</option>
                <option value="retro">Retro</option>
                <option value="cyberpunk">Cyberpunk</option>
                <option value="valentine">Valentine</option>
                <option value="aqua">Aqua</option>
                <option value="dracula">Dracula</option>
                <option value="nord">Nord</option>
            </select>
            <ul class="menu menu-horizontal px-1">
                <li><NavLink href="" Match="NavLinkMatch.All">Home</NavLink></li>
                <li><NavLink href="counter">Counter</NavLink></li>
            </ul>
        </div>
    </header>

    <main class="flex-grow container mx-auto p-4 md:p-8">
        @Body
    </main>

    <footer class="footer footer-center p-4 bg-base-300 text-base-content">
        <aside>
            <p>PboWasm - QR & Camera Proof of Concept</p>
        </aside>
    </footer>
</div>

@code {
    private async Task ChangeTheme(ChangeEventArgs e)
    {
        var theme = e.Value?.ToString();
        if (!string.IsNullOrEmpty(theme))
        {
            await JSRuntime.InvokeVoidAsync("themeManager.setTheme", theme);
        }
    }

    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
}
