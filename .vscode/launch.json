{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch and Debug Blazor WASM",
            "type": "blazorwasm",
            "request": "launch",
            "preLaunchTask": "build",
            "url": "http://localhost:5100",
            "browser": "chrome",
            "cwd": "${workspaceFolder}/PboWasm.Web",
            "inspectUri": "{wsProtocol}://{url.hostname}:{url.port}/_framework/debug/ws-proxy?browser={browserInspectUri}"
        },
        {
            "name": "Launch MAUI Windows App",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build-maui-windows",
            "program": "${workspaceFolder}/PboWasm.Maui/bin/Debug/net10.0-windows10.0.19041.0/win-x64/PboWasm.Maui.exe",
            "args": [],
            "cwd": "${workspaceFolder}/PboWasm.Maui",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": ".NET MAUI App (Android/iOS/Windows)",
            "type": "maui",
            "request": "launch"
        }
    ]
}
