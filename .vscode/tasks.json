{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build-css",
            "type": "shell",
            "command": "npm run build:css",
            "options": {
                "cwd": "${workspaceFolder}/PboWasm.Shared"
            },
            "problemMatcher": []
        },
        {
            "label": "watch-css",
            "type": "shell",
            "command": "npm run watch:css",
            "options": {
                "cwd": "${workspaceFolder}/PboWasm.Shared"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/PboWasm.Web/PboWasm.Web.csproj",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoColor"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "build-maui-windows",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/PboWasm.Maui/PboWasm.Maui.csproj",
                "-f",
                "net10.0-windows10.0.19041.0",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoColor"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
